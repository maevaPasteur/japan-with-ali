function build(){
  const nav=document.getElementById('nav');
  const cont=document.getElementById('cont');
  D.forEach((d,i)=>{
    const btn=document.createElement('button');
    btn.className='nb'+(d.navClass?' '+d.navClass:'')+(i===0?' act':'');
    btn.innerHTML=(d.nav||'').replace('\n','<br>');
    btn.onclick=()=>{
      document.querySelectorAll('.nb').forEach(x=>x.classList.remove('act'));
      document.querySelectorAll('.day').forEach(x=>x.classList.remove('act'));
      btn.classList.add('act');
      document.getElementById(d.id).classList.add('act');
      window.scrollTo(0,0);
    };
    nav.appendChild(btn);

    const div=document.createElement('div');
    div.id=d.id;
    div.className='day'+(i===0?' act':'');

    // bag status
    const bagColors={full:'move',light:'',send:'',hotel:'safe'};
    const bagIcons={full:'🧳🧳🧳🧳 Valises avec vous',light:'🎒 Sacs légers',send:'📦 Envoi Takkyubin',hotel:'🏨 Valises sécurisées à l\'hôtel'};

    let h=`<div class="dh"><h2>${d.title}</h2><div class="dmeta"><span>${d.loc||''}</span><span>${d.wx||''}</span><span>${d.sk||''}</span></div><div class="dbadge">${(d.badges||[]).map(x=>`<span class="bdg">${x}</span>`).join('')}</div></div>`;

    if(d.bagNote){
      const cls=d.bags==='hotel'?'safe':d.bags==='send'?'':d.bags==='light'?'':'move';
      h+=`<div class="bag-status ${cls}">🧳 ${d.bagNote}</div>`;
    }
    (d.alerts||[]).forEach(a=>h+=`<div class="al ${a.t}">${a.m}</div>`);
    h+='<div class="tl">';
    (d.blocks||[]).forEach(b=>{
      h+=`<div class="bl ${b.type}"><div class="tc">${b.ti}</div><div class="dc"><div class="dot"></div><div class="dl"></div></div><div class="cc"><div class="btt">${b.n}</div><div class="bd">${b.d}</div>${b.tip?`<div class="tip">💡 ${b.tip}</div>`:''}<div class="dur">${b.dur||''}</div></div></div>`;
    });
    h+='</div>';
    div.innerHTML=h;
    cont.appendChild(div);
  });
}
build();
